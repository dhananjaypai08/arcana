# ARCANA Contracts — Environment Variables
# Copy to .env and fill in values

# Deployer wallet private key (must have HSK for gas)
PRIVATE_KEY=0x<YOUR_PRIVATE_KEY>

# HashKey Chain RPC
HASHKEY_RPC=https://mainnet.hsk.xyz

# HashKey Chain Explorer API key (for verification)
ETHERSCAN_API_KEY=placeholder

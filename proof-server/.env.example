# ARCANA Proof Server — Environment Variables
# Copy to .env and fill in values

# HashKey Chain RPC
HASHKEY_RPC=https://mainnet.hsk.xyz

# HSP (HashKey Settlement Protocol)
HSP_COORDINATOR_URL=<COORDINATOR_URL>
HSP_API_KEY=<YOUR_TEAM_API_KEY>
HSP_ADAPTER_ADDRESS=<ADAPTER_ADDRESS_FROM_CHAINS_ENDPOINT>
HSP_ENABLED=true
HSP_DEMO_FALLBACK=true

# Contract addresses (from contracts/deployments.json after deployment)
ARCANA_VERIFIER_ADDRESS=
ARCANA_CRED_ADDRESS=
ARCANA_LEND_ADDRESS=
ARCANA_PLEDGE_ADDRESS=

# Server config
PORT=8000
LOG_LEVEL=info

# ARCANA Proof Server — Environment Variables
# Copy to .env and fill in values

# HashKey Chain RPC (use testnet.hsk.xyz while contracts are on testnet —
# mainnet.hsk.xyz will not see the addresses below)
HASHKEY_RPC=https://testnet.hsk.xyz

# HSP (HashKey Settlement Protocol)
HSP_COORDINATOR_URL=<COORDINATOR_URL>
HSP_API_KEY=<YOUR_TEAM_API_KEY>
HSP_ADAPTER_ADDRESS=<ADAPTER_ADDRESS_FROM_CHAINS_ENDPOINT>
HSP_ENABLED=true
HSP_DEMO_FALLBACK=true

# Contract addresses (from contracts/deployments.json after deployment)
ARCANA_VERIFIER_ADDRESS=0xd8611665C78345cFb47b3D3F16642C43e9E822Ed
ARCANA_CRED_ADDRESS=0xB5935FbE9BB2C769661a7ACE9EC6992D6C5Ca2C2
ARCANA_LEND_ADDRESS=0xB4B45E802Aedf148B87FeC835dFA3D2BA18a9982
ARCANA_PLEDGE_ADDRESS=0xac984E1275ffEC692479C8b91aF63365435330F5
USDC_ADDRESS=0x770E1C48309e0e42d9aaA409042e7c77Cb30c9c5

# Server config
PORT=8000
LOG_LEVEL=info
